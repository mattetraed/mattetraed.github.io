<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MatteTräd</title>
    <link rel="stylesheet" href="styles.css">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
    <!-- Login Screen -->
    <div id="loginScreen" class="login-screen active">
        <div class="login-container">
            <div class="login-title">Logga in</div>
            <form id="loginForm">
                <div class="login-field">
                    <label for="loginUsername">Användarnamn</label>
                    <input type="text" id="loginUsername" placeholder="Ange användarnamn" autocomplete="username" required>
                </div>
                <div class="login-field">
                    <label for="loginPin">PIN / Lösenord</label>
                    <input type="password" id="loginPin" placeholder="Ange PIN eller lösenord" autocomplete="current-password" required>
                </div>
                <button type="submit" class="login-btn" id="loginBtn">Logga in</button>
            </form>
            <div class="login-error" id="loginError"></div>
        </div>
    </div>

    <!-- Game Container -->
    <div class="game-container" id="gameContainer">
        <div class="container">
            <h1 class="game-title">MatteTräd</h1>
            <div class="status">
                <span>Nivå: <span id="level">0</span> |</span>
                <span>Status: <span id="counter">0</span>/<span id="required">6</span> rätt</span>
                <span>
                    <button class="logout-btn" onclick="logout()">Logga ut</button>
                </span>
            </div>
            <div class="question" id="question">5 - 2 = ?</div>
            <div class="feedback" id="feedback"></div>
            <div class="answers" id="answers"></div>
            <div id="winMessage"></div>
        </div>
    </div>

    <script type="module" src="app.js"></script>
</body>
</html>
